# Copy to .env.local and fill in a key to enable real LLM-driven audits.
# With NO key set, the app still runs — it uses the deterministic fallback.

# Anthropic Claude (preferred). Get a key at https://platform.claude.com
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-8           # optional: claude-sonnet-4-6, claude-haiku-4-5

# Google Gemini (free tier). Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash       # optional

# Scrape tuning
# MAX_PRODUCTS=30
